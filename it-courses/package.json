{
  "name": "it-courses",
  "version": "1.0.0",
  "description": "IT Courses platform - combined lab works",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "json-server": "json-server --watch db.json --port 3001",
    "build-css": "sass scss/main.scss public/css/style.css",
    "watch-css": "sass --watch scss/main.scss:public/css/style.css",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:contract": "jest tests/contract",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.js --ui",
    "test:ai-e2e:prompt": "node scripts/ai-e2e/end_to_end_runner.js"
  },
  "keywords": ["courses", "education", "it"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jest": "^29.7.0",
    "json-server": "^0.17.4",
    "nock": "^13.5.6",
    "nodemon": "^3.0.1",
    "sass": "^1.69.5",
    "supertest": "^7.0.0",
    "@playwright/test": "^1.49.0"
  }
}

