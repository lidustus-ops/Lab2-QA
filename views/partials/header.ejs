<header class="header<%= typeof headerClass !== 'undefined' && headerClass ? ' ' + headerClass : '' %>" role="banner">
  <div class="container">
    <div class="header__content">
      <button class="header__menu-toggle" aria-label="Open menu" id="menuToggle">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="12" y="20" width="40" height="4" rx="2" fill="white"/>
          <rect x="12" y="30" width="40" height="4" rx="2" fill="white"/>
          <rect x="12" y="40" width="40" height="4" rx="2" fill="white"/>
        </svg>
      </button>
      <nav class="header__nav" role="navigation" aria-label="Main navigation">
        <% if (typeof headerClass !== 'undefined' && headerClass === 'header--catalog') { %>
          <a href="/" class="header__profile-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z" fill="currentColor"/>
            </svg>
          </a>
        <% } else if (typeof headerClass !== 'undefined' && headerClass === 'header--home') { %>
          <!-- No button or icon on home page -->
        <% } else { %>
          <a href="/checkout" class="header__signup btn btn--primary">Sign up</a>
        <% } %>
      </nav>
    </div>
  </div>
</header>

